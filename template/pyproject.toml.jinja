[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = ""
authors = [
    { name = "{{ author_name }}" }
]
requires-python = ">={{ python_version }}"
dependencies = []

[project.optional-dependencies]
tech-watch = [
    "feedparser>=6.0",
    "huggingface_hub>=0.20",
]

[dependency-groups]
dev = [
    "pytest>=8.3.0",
    "ruff>=0.11.0",
    "pre-commit>=4.2.0",
]

[build-system]
requires = ["uv_build>=0.11.2,<0.12"]
build-backend = "uv_build"

[tool.ruff]
target-version = "py312"
# Deviation from PEP 8 (79), Black (88), Google (80).
# Justification: CLI error messages and argparse help strings read better without wrap.
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "W", "I", "N", "UP", "B", "SIM"]
# line-length is a ruff-format target, not a hard-block (DX).
# Semantic rules (F, W, B, SIM, etc.) stay enforced.
ignore = ["E501"]

[tool.ruff.format]
quote-style = "double"

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src", "."]
