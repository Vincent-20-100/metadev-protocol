[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = ""
authors = [
    { name = "{{ author_name }}" }
]
requires-python = ">={{ python_version }}"
dependencies = []

[project.optional-dependencies]
radar = [
    "feedparser>=6.0",
    "huggingface_hub>=0.20",
]

[dependency-groups]
dev = [
    "pytest>=8.3.0",
    "ruff>=0.11.0",
    "pre-commit>=4.2.0",
]

[build-system]
requires = ["uv_build>=0.11.2,<0.12"]
build-backend = "uv_build"

[tool.ruff]
target-version = "py312"
line-length = 88

[tool.ruff.lint]
select = ["E", "F", "W", "I", "N", "UP", "B", "SIM"]

[tool.ruff.format]
quote-style = "double"

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src", "."]
