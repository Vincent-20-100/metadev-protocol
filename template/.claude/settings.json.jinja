{
  "attribution": {
    "commit": ""
  },
  "env": {
    "GIT_AUTHOR_NAME": "{{ author_name }}",
    "GIT_AUTHOR_EMAIL": "{{ author_email }}",
    "GIT_COMMITTER_NAME": "{{ author_name }}",
    "GIT_COMMITTER_EMAIL": "{{ author_email }}"
  },
  "permissions": {
{%- if execution_mode == 'safe' %}
    "allow": [
      "Bash(uv *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git pull)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(pre-commit *)",
      "Bash(copier *)",
      "Read",
      "Glob",
      "Grep",
      "TodoWrite",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(.meta/**)",
      "Edit(docs/**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(.meta/**)",
      "Write(docs/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(mkdir *)",
      "Edit(pyproject.toml)",
      "Edit(.gitignore)",
      "Edit(.pre-commit-config.yaml)",
      "Edit(CLAUDE.md)",
      "Edit(README.md)",
      "Edit(.claude/**)",
      "Edit(.github/**)",
      "Write(*)"
    ],
{%- else %}
    "allow": [
      "Bash(*)",
      "Read",
      "Glob",
      "Grep",
      "TodoWrite",
      "Edit(*)",
      "Write(*)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [],
{%- endif %}
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(.git/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.pypirc)",
      "Read(~/.netrc)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/force_git_author.py",
            "if": "Bash(git commit *)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -I {} sh -c 'case \"{}\" in *.py) uv run ruff format \"{}\" 2>/dev/null && uv run ruff check \"{}\" --fix 2>/dev/null;; esac; exit 0'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$CLAUDE_CODE_REMOTE_ENVIRONMENT_TYPE\" ]; then IDENTITY=\"\"; [ -f .claude/identity.local.yaml ] && IDENTITY=.claude/identity.local.yaml; [ -z \"$IDENTITY\" ] && [ -f .claude/identity.yaml ] && IDENTITY=.claude/identity.yaml; if [ -n \"$IDENTITY\" ]; then NAME=$(sed -n 's/^name:[[:space:]]*//p' \"$IDENTITY\" | head -1); EMAIL=$(sed -n 's/^email:[[:space:]]*//p' \"$IDENTITY\" | head -1); git config --local user.name \"$NAME\" 2>/dev/null; git config --local user.email \"$EMAIL\" 2>/dev/null; git config --local commit.gpgsign false 2>/dev/null; command -v pre-commit >/dev/null 2>&1 && pre-commit install --install-hooks 2>/dev/null || true; echo \">>> Claude Code remote: git identity set to $NAME from $IDENTITY\" >&2; else echo \">>> Claude Code remote detected but no .claude/identity.yaml found\" >&2; fi; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "grep -q 'first_session: true' .meta/PILOT.md 2>/dev/null && echo '>>> FIRST SESSION DETECTED — Welcome! Read PILOT.md for project overview and available skills.' || cat .meta/PILOT.md 2>/dev/null | head -30 || true"
          }
        ]
      }
    ]
  }
}
