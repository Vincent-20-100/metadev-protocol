# GitHub personal access token
# Required by scripts/tech_watch.py to query the GitHub Search API.
# Unauth rate limit (60 req/h) is too low for 6 topics — token is mandatory.
#
# Create one at: https://github.com/settings/tokens
# Scope required: read:public_repo (or just "public_repo")
#
# Copy this file to .env and fill in your token:
#   cp .env.example .env
#
GITHUB_TOKEN=
