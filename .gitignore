# Build artifacts and cache
.venv/
venv/
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# Environment
.env
.env.*
!.env.example

# Coverage and test caches
.coverage
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS / IDE
.DS_Store
.idea/
.vscode/

# Node (if any)
node_modules/

# Meta protocol — ephemeral drafts
.meta/drafts/*
!.meta/drafts/.gitkeep

# Claude Code — local settings (never commit)
.claude/settings.local.json

# Tech watch dedup cache
.meta/references/raw/.tech-watch-seen.json

# scratch — ephemeral session notes (equivalent to drafts/)
.meta/scratch/
